{
  "name": "packagehub",
  "private": true,
  "description": "Publish packages across registries (npm, PyPI, Crates.io, etc.) from one dashboard with OIDC and managed GitHub workflows.",
  "scripts": {
    "dev": "pnpm --filter packagehub-web dev",
    "dev:docs": "pnpm --filter packagehub-docs dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter packagehub-web build",
    "build:docs": "pnpm --filter packagehub-docs build"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "create-fumadocs-app": "^16.0.72"
  }
}
